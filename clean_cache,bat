# Remove __pycache__ directories
Get-ChildItem -Path . -Directory -Name __pycache__ -Recurse | ForEach-Object { Remove-Item -Path $_ -Recurse -Force -ErrorAction SilentlyContinue }

# Remove .pytest_cache
Remove-Item -Path .\.pytest_cache -Recurse -Force -ErrorAction SilentlyContinue

# Remove .pyc files
Get-ChildItem -Path . -Filter *.pyc -Recurse | Remove-Item -Force -ErrorAction SilentlyContinue

# Remove .coverage
Remove-Item -Path .\.coverage -Force -ErrorAction SilentlyContinue

# Remove htmlcov directory
Remove-Item -Path .\htmlcov -Recurse -Force -ErrorAction SilentlyContinue

Write-Host "Cache cleaned!" -ForegroundColor Green